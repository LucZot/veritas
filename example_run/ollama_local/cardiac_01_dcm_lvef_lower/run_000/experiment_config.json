{
  "llm_provider": "ollama",
  "execution_mode": "langgraph",
  "context_length": 16384,
  "prompt_verbosity": "standard",
  "temperature": 0.2,
  "models": {
    "pi": "gpt-oss:20b",
    "imaging_discussion": "gpt-oss:20b",
    "imaging_execution": "gpt-oss:20b",
    "statistician_discussion": "qwen3:8b",
    "statistician_coding": "qwen3-coder:30b",
    "critic": "qwen3:8b"
  },
  "dataset_path": "$BIO_DATA_ROOT/ACDC/database",
  "dataset": {
    "name": "acdc",
    "domain": "cardiac_mri",
    "modality": "Cine MRI (short-axis stack)",
    "available_groups": [
      "DCM",
      "HCM",
      "MINF",
      "NOR",
      "RV"
    ],
    "available_observations": [
      "ED",
      "ES"
    ],
    "patient_metadata_fields": [
      "height",
      "weight",
      "ed_frame",
      "es_frame",
      "num_frames"
    ],
    "ground_truth_structures": [
      "LV",
      "RV",
      "Myo"
    ],
    "domain_notes": "Cardiac MRI with temporal phases: ED (end-diastole) and ES (end-systole). LVEF = ((LVEDV - LVESV) / LVEDV) \u00d7 100. Patient groups: DCM (dilated cardiomyopathy), HCM (hypertrophic cardiomyopathy), MINF (myocardial infarction), NOR (normal controls), RV (right ventricle abnormality)."
  },
  "sat_cache_database": "$BIO_DATA_ROOT/sat_cache/acdc",
  "use_ground_truth": false,
  "enable_critic": true,
  "enable_critic_phase1": false,
  "enable_critic_phase3": false,
  "run_phase1": true,
  "run_phase2a": true,
  "run_phase2b": true,
  "run_phase3": true,
  "output_path": "results/experiments/exp_20260304_023048_acdc_def_1st/cardiac_01_dcm_lvef_lower/run_000",
  "experiment_name": "cardiac_01_dcm_lvef_lower",
  "description": "Default configuration with 16k context window",
  "hypothesis": "DCM patients show significantly lower LVEF than normal controls",
  "max_transient_retries_per_phase": 1
}